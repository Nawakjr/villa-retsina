# ── Resend (formulaire de contact) ──
# Clé API Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# Adresse qui reçoit les demandes du formulaire de contact
MAIL_TO_CONTACT=contact@villa-retsina.com

# Expéditeur vérifié dans Resend (domaine validé)
MAIL_FROM=Villa Retsina <no-reply@villa-retsina.com>

# ── Administration (/admin) ──
# Mot de passe d'accès à la page d'administration
ADMIN_PASSWORD=change-moi
# Secret pour signer le cookie de session (chaîne aléatoire longue)
ADMIN_SECRET=remplace-par-une-chaine-aleatoire

# ── Stockage des dispos/tarifs en production (KV) ──
# OBLIGATOIRE en production : sur Vercel le système de fichiers est en lecture
# seule, l'admin ne peut donc PAS sauvegarder sans un store KV.
# Connecte un store via Vercel → Storage (KV ou Upstash Redis) : les variables
# ci-dessous sont alors ajoutées AUTOMATIQUEMENT au projet.
# En local, rien à remplir : l'admin écrit dans .data/store.json.
#
# Convention Vercel KV :
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Convention Upstash :
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
